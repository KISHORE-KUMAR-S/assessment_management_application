# Server config
PORT=5000
NODE_ENV=development

# Mongo connection (Atlas URI or local mongodb://localhost:27017/assessments)
MONGO_URI=

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# CORS origin (frontend url)
CLIENT_ORIGIN=http://localhost:5173

# Set to 1 in production when running behind a hosting proxy (Render, etc.)
# so the rate limiter keys on the real client IP. Leave unset locally.
TRUST_PROXY=
